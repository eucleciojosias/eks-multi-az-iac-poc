{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadInfrastructureForPlan",
      "Effect": "Allow",
      "Action": [
        "ec2:Describe*",
        "eks:Describe*",
        "eks:List*",
        "iam:Get*",
        "iam:List*",
        "logs:Describe*",
        "logs:ListTagsForResource",
        "kms:Describe*",
        "kms:GetKeyPolicy",
        "kms:GetKeyRotationStatus",
        "kms:ListAliases",
        "kms:ListResourceTags",
        "elasticloadbalancing:Describe*",
        "autoscaling:Describe*"
      ],
      "Resource": "*"
    },
    {
      "Sid": "StateBucketList",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::<PROJECT>-tfstate"
    },
    {
      "Sid": "StateRead",
      "Effect": "Allow",
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::<PROJECT>-tfstate/<PROJECT>/infra.tfstate"
    },
    {
      "Sid": "StateLockOnly",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject", "s3:DeleteObject"],
      "Resource": "arn:aws:s3:::<PROJECT>-tfstate/<PROJECT>/infra.tfstate.tflock"
    }
  ]
}
